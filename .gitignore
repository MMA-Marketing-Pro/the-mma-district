# Internal build artifacts — keep templates in their own folder
# The rendered HTML files in the repo root are the canonical site
_build/
scrape/
pages.json

# Source media originals — the web-optimized versions in videos/ are canonical.
# Anchored to the repo root so optimized clips in videos/ stay tracked.
*.mov
/*.mp4
/*.HEIC
/*.heic

# OS junk
.DS_Store
Thumbs.db

# Editor junk
*.swp
*.swo
.vscode/
.idea/

# Node modules (no JS dependencies needed for the static site)
node_modules/
/*.jpeg
/*.dng
